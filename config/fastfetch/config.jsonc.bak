{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo":{
    "source":"~/.config/hypr/logo.txt",
    "color":{
        "1": "#74c7ec"
    },
    "padding":{
        "top":2,
        "right":4
    }
  },
  "display":{
    "separator":" ➜ ",
    "key": {
        "width":15
    },
    "percent":{
        "type":3
    }
  },
  "modules": [
    "title",
    "separator",
    "os",
    "host",
    "kernel",
    "uptime",
    "packages",
    "shell",
    "display",
    "de",
    "wm",
    "wmtheme",
    "theme",
    "icons",
    "font",
    "cursor",
    "terminal",
    "terminalfont",
    "cpu",
    "gpu",
    "memory",
    "swap",
    "disk",
    "localip",
    "battery",
    "poweradapter",
    "locale",
    "break",
    "colors"
  ]
}
